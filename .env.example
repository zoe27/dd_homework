# 钉钉应用配置（在 open.dingtalk.com 创建企业内部应用后填入）
DINGTALK_APP_KEY=your_app_key_here
DINGTALK_APP_SECRET=your_app_secret_here

# 目标群 ID（在钉钉群设置 → 群信息中查看）
TARGET_GROUP_ID=your_group_id_here

# 打印机名称（留空使用系统默认打印机）
# PRINTER_NAME=

# 消息缓存上限
# MESSAGE_STORE_LIMIT=100

# 日志级别
# LOG_LEVEL=INFO

# v2 工作通知 capture：非今天时 stop=停止向上扫描，continue=跳过并继续找（测试用，凑满条数/到顶）
# CAPTURE_V2_ON_NON_TODAY=stop
# CAPTURE_V2_MAX_HOMEWORK=6
